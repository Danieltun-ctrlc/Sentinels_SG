PORT=5000
NODE_ENV=development

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=sentinel_sg

JWT_SECRET=replace_with_long_random_string
JWT_EXPIRES_IN=7d

CLIENT_URL=http://localhost:3000

# OpenRouter AI (for Fact-Checker)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL_DETECTOR=anthropic/claude-sonnet-4.6
OPENROUTER_MODEL_SKEPTIC=anthropic/claude-sonnet-4.6
OPENROUTER_MODEL_VISION=anthropic/claude-sonnet-4.6
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=Sentinel SG

# Fact-Checker Settings
FACTCHECK_MODE=live
FACTCHECK_MAX_FILE_SIZE_MB=10
FACTCHECK_TIMEOUT_MS=30000
FACTCHECK_MIN_PROCESSING_TIME_MS=3000
